    def do_POST(self):
                                   
        stats["requests"] += 1

        parsed_path = urllib.parse.urlparse(self.path)
        path = parsed_path.path

        if path == "/predict":
            content_length = int(self.headers["Content-Length"])
            post_data = self.rfile.read(content_length)

            try:
                data = json.loads(post_data.decode())

                cve_id = data.get("cve_id", "")

                base_score = 5.0
                if "base_score" in data:
                    base_score = float(data["base_score"])
                elif "severity" in data:
                    base_score = float(data["severity"])

                prediction = forecaster.predict_threat(cve_id, base_score)

                if ml_model and hasattr(ml_model, "predict_proba") and "CVE-" in cve_id:
                    try:
                        cve_year = int(cve_id.split("-")[1])
                        prediction_proba = ml_model.predict_proba([[cve_year, base_score]])[0]
                        prediction["ml_confidence"] = float(prediction_proba[1])

                        if "feature_importance" in model_metadata:
                            prediction["feature_importance"] = model_metadata["feature_importance"]
                    except Exception as e:
                        print(f"Error calculating ML confidence: {e}")

                self._set_headers()
                self.wfile.write(json.dumps(prediction).encode())
                stats["predictions"] += 1

            except Exception as e:
                self.send_response(400)
                self.send_header("Content-type", "application/json")
                self.end_headers()
                self.wfile.write(json.dumps({
                    "error": str(e),
                    "timestamp": datetime.now().isoformat()
                }).encode())
                stats["errors"] += 1

        else:
            self.send_response(404)
            self.send_header("Content-type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps({"error": "Not found"}).encode())

