                activities = [day.get("expected_activity", 0) for day in activity_forecast]
                mean_activity = sum(activities) / len(activities)
                std_dev = (sum((x - mean_activity) ** 2 for x in activities) / len(activities)) ** 0.5
                
                anomalies = []
                for i, day in enumerate(activity_forecast):
                    activity = day.get("expected_activity", 0)
                    z_score = (activity - mean_activity) / std_dev if std_dev > 0 else 0
                    
                    if abs(z_score) > 2:
                        anomalies.append({
