def calculate_trend(data_points):
                                                      
    if not data_points or len(data_points) < 2:
        return {"direction": "stable", "magnitude": 0.0}

    x = list(range(len(data_points)))
    y = data_points

    n = len(x)
    x_mean = sum(x) / n
    y_mean = sum(y) / n
    
    numerator = sum((x[i] - x_mean) * (y[i] - y_mean) for i in range(n))
    denominator = sum((x[i] - x_mean) ** 2 for i in range(n))
    
    if denominator == 0:
        slope = 0
    else:
        slope = numerator / denominator

    if y_mean != 0:
        normalized_slope = (slope / y_mean) * 100
    else:
        normalized_slope = 0

    if normalized_slope > 5:
        direction = "increasing"
    elif normalized_slope < -5:
        direction = "decreasing"
    else:
        direction = "stable"
    
    return {
        "direction": direction,
        "magnitude": abs(normalized_slope),
        "raw_slope": slope
    }

def calculate_confidence_intervals(values, confidence=0.95):
                                                            
    if not values or len(values) < 2:
        return {"mean": 0, "lower": 0, "upper": 0}
    
    import scipy.stats as st
    
    mean = sum(values) / len(values)

    std_err = (sum((x - mean) ** 2 for x in values) / (len(values) - 1)) ** 0.5 / (len(values) ** 0.5)
    interval = std_err * st.t.ppf((1 + confidence) / 2, len(values) - 1)
    
    return {
        "mean": mean,
        "lower": mean - interval,
        "upper": mean + interval
    }

def predict_next_values(historical_values, days_to_predict=7):
                                                                                  
    if not historical_values or len(historical_values) < 5:
        return []

    values = historical_values.copy()
    mean = sum(values) / len(values)

    n = len(values)
    lag1_autocorr = sum((values[i] - mean) * (values[i-1] - mean) for i in range(1, n)) /                    sum((values[i] - mean) ** 2 for i in range(n))

    predictions = []
    last_value = values[-1]
    
    for _ in range(days_to_predict):
        next_value = mean + lag1_autocorr * (last_value - mean)
        predictions.append(next_value)
        last_value = next_value
    
    return predictions

def analyze_cve_patterns(cves):
                                                     
    if not cves:
        return {"error": "No CVE data available"}
    
    severity_counts = {"CRITICAL": 0, "HIGH": 0, "MEDIUM": 0, "LOW": 0, "UNKNOWN": 0}
    exploit_counts = {"EXPLOITED": 0, "NOT_EXPLOITED": 0}
    cve_years = {}
    
    for cve in cves:
                           
        severity = cve.get("severity", "UNKNOWN").upper()
        if severity not in severity_counts:
            severity = "UNKNOWN"
        severity_counts[severity] += 1

        if cve.get("exploited", False) or cve.get("source") == "CISA KEV":
            exploit_counts["EXPLOITED"] += 1
        else:
            exploit_counts["NOT_EXPLOITED"] += 1

        if "cve_id" in cve and cve["cve_id"]:
            try:
                year = cve["cve_id"].split("-")[1]
                cve_years[year] = cve_years.get(year, 0) + 1
            except IndexError:
                pass

    years = sorted(cve_years.keys())
    year_trend = [{"year": year, "count": cve_years[year]} for year in years]

    total_cves = exploit_counts["EXPLOITED"] + exploit_counts["NOT_EXPLOITED"]
    exploit_ratio = exploit_counts["EXPLOITED"] / total_cves if total_cves > 0 else 0
    
    return {
        "severity_distribution": [
            {"severity": severity, "count": count} 
            for severity, count in severity_counts.items() if count > 0
        ],
        "exploit_status": exploit_counts,
        "exploit_ratio": exploit_ratio,
        "cve_by_year": year_trend,
        "total_cves": len(cves)
    }

def analyze_apt_tactics(apt_data):
                                            
    if not apt_data:
        return {"error": "No APT data available"}
    
    technique_counts = {}
    group_tactics = {}
    
    for apt in apt_data:
        group = apt.get("group", "unknown")
        name = apt.get("name", group)
        
        if group not in group_tactics:
            group_tactics[group] = {
                "name": name,
                "techniques": {},
                "activity_count": apt.get("activity_count", 0)
            }

        for technique in apt.get("techniques", []):
            technique_counts[technique] = technique_counts.get(technique, 0) + 1
            group_tactics[group]["techniques"][technique] = group_tactics[group]["techniques"].get(technique, 0) + 1

    technique_combinations = []

    sorted_techniques = sorted(
        technique_counts.items(), 
        key=lambda x: x[1], 
        reverse=True
    )

    sorted_groups = sorted(
        group_tactics.items(),
        key=lambda x: x[1]["activity_count"],
        reverse=True
    )
    
    return {
        "top_techniques": [
            {"technique": technique, "count": count}
            for technique, count in sorted_techniques[:10]
        ],
        "top_threat_actors": [
            {
                "group": group,
                "name": data["name"],
                "activity_count": data["activity_count"],
                "primary_techniques": sorted(
                    data["techniques"].items(),
                    key=lambda x: x[1],
                    reverse=True
                )[:3] if data["techniques"] else []
            }
            for group, data in sorted_groups[:10]
        ],
        "technique_combinations": technique_combinations
    }

def analyze_geographic_patterns(geo_data):
                                                    
    if not geo_data:
        return {"error": "No geographic data available"}
    
    country_counts = {}
    ip_data = {}
    
    for location in geo_data:
        country = location.get("country", location.get("country_code", "Unknown"))
        country_counts[country] = country_counts.get(country, 0) + 1
        
        ip = location.get("ip")
        if ip:
            ip_data[ip] = country

    sorted_countries = sorted(
        country_counts.items(),
        key=lambda x: x[1],
        reverse=True
    )
    
    return {
        "active_countries": [
            {"country": country, "activity_level": count}
            for country, count in sorted_countries
        ],
        "total_locations": len(geo_data),
        "unique_countries": len(country_counts)
    }

