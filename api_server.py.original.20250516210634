                    }).encode())
                    stats["errors"] += 1
                    return
                
                # Extract features
                # Feature 1: CVE year
                cve_year = 2020  # Default
                if "cve_id" in data and re.match(r"CVE-\d+-\d+", data["cve_id"]):
                    try:
                        cve_year = int(data["cve_id"].split("-")[1])
